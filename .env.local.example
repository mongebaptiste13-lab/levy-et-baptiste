# ─────────────────────────────────────────────────────────
#  Copier ce fichier en .env.local et remplir les valeurs
# ─────────────────────────────────────────────────────────

# Clé API Resend (gratuit : 3 000 emails/mois)
# → Créer un compte sur https://resend.com
# → Récupérer la clé dans Dashboard > API Keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX

# Email qui recevra tous les formulaires (contact + candidatures)
CONTACT_EMAIL=ton-email@domaine.fr

# URL Calendly pour la prise de rendez-vous visio
# → Créer un compte sur https://calendly.com
# → Copier le lien de l'événement 30 min
CALENDLY_URL=https://calendly.com/ton-username/30min

# URL publique du site (pour les liens dans les emails)
NEXT_PUBLIC_SITE_URL=https://dataforge-ia.fr
